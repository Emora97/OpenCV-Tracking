"""
Clean camera calibration script

This combines two steps into one workflow:
1. Extract candidate calibration frames from a video.
2. Detect chessboard corners and compute camera calibration.

Typical use:
    python clean_camera_calibration.py

Edit the USER SETTINGS section below before running.
"""

import glob
from pathlib import Path

import cv2
import numpy as np


# =========================
# USER SETTINGS
# =========================
VIDEO_PATH = "calib_marker_markerless.mov"
OUTPUT_DIR = "new_calib"
OUTPUT_CALIBRATION_FILE = "iphone_calibration.npz"

EXTRACT_FRAMES = True          # True: pull frames from video first
CLEAR_OLD_FRAMES = False       # True: delete old extracted .png frames before saving new ones
SAMPLE_EVERY = 15              # Save every Nth frame to avoid near-duplicates
IMAGE_EXTENSION = "*.png"

CHESSBOARD_SIZE = (9, 6)       # Internal corners, not number of printed squares
SQUARE_SIZE = 25.4             # mm; 25.4 mm = 1 inch
MIN_ACCEPTED_IMAGES = 10       # Prefer 10-15+ good detections
SHOW_CORNERS = False           # True: preview accepted detections
PREVIEW_DELAY_MS = 200
# =========================


def extract_candidate_frames(video_path, output_dir, sample_every=15, clear_old_frames=False):
    """Extract every Nth frame from a calibration video."""
    video_path = Path(video_path)
    output_dir = Path(output_dir)
    output_dir.mkdir(parents=True, exist_ok=True)

    if not video_path.exists():
        raise FileNotFoundError(f"Video not found: {video_path}")

    if clear_old_frames:
        for old_frame in output_dir.glob("frame_*.png"):
            old_frame.unlink()

    cap = cv2.VideoCapture(str(video_path))
    if not cap.isOpened():
        raise RuntimeError(f"Could not open video: {video_path}")

    frame_count = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))
    frame_idx = 0
    saved_idx = 0

    print("\n--- Extracting calibration frames ---")
    print(f"Video: {video_path}")
    print(f"Output folder: {output_dir}")
    print(f"Sample every: {sample_every} frames")

    while True:
        ret, frame = cap.read()
        if not ret:
            break

        if frame_idx % sample_every == 0:
            out_path = output_dir / f"frame_{saved_idx:03d}.png"
            cv2.imwrite(str(out_path), frame)
            saved_idx += 1

        frame_idx += 1

        if frame_count > 0 and frame_idx % 300 == 0:
            pct = 100 * frame_idx / frame_count
            print(f"Processed {frame_idx}/{frame_count} frames ({pct:.1f}%)")

    cap.release()
    print(f"Saved {saved_idx} candidate frames.\n")
    return saved_idx


def make_object_points(chessboard_size, square_size):
    """Create ideal 3D chessboard corner coordinates in the board plane."""
    objp = np.zeros((chessboard_size[0] * chessboard_size[1], 3), np.float32)
    objp[:, :2] = np.mgrid[0:chessboard_size[0], 0:chessboard_size[1]].T.reshape(-1, 2)
    objp *= square_size
    return objp


def find_corners(gray, chessboard_size, criteria):
    """Try standard chessboard detection, then the stronger SB detector if available."""
    found, corners = cv2.findChessboardCorners(gray, chessboard_size, None)

    if found:
        corners = cv2.cornerSubPix(gray, corners, (11, 11), (-1, -1), criteria)
        return True, corners

    if hasattr(cv2, "findChessboardCornersSB"):
        found, corners = cv2.findChessboardCornersSB(gray, chessboard_size, None)
        if found:
            return True, corners

    return False, None


def compute_mean_reprojection_error(objpoints, imgpoints, rvecs, tvecs, camera_matrix, dist_coeffs):
    """Compute mean reprojection error across all accepted calibration images."""
    total_error = 0.0

    for i, objp in enumerate(objpoints):
        projected_imgpoints, _ = cv2.projectPoints(
            objp,
            rvecs[i],
            tvecs[i],
            camera_matrix,
            dist_coeffs,
        )
        error = cv2.norm(imgpoints[i], projected_imgpoints, cv2.NORM_L2) / len(projected_imgpoints)
        total_error += error

    return total_error / len(objpoints)


def calibrate_from_images(
    image_folder,
    image_extension,
    chessboard_size,
    square_size,
    min_accepted_images=10,
    show_corners=False,
    preview_delay_ms=200,
):
    """Detect chessboard corners in extracted images and calibrate the camera."""
    image_folder = Path(image_folder)
    images = sorted(glob.glob(str(image_folder / image_extension)))

    if not images:
        raise FileNotFoundError(f"No images found in {image_folder} matching {image_extension}")

    criteria = (
        cv2.TERM_CRITERIA_EPS + cv2.TERM_CRITERIA_MAX_ITER,
        30,
        0.001,
    )

    objp = make_object_points(chessboard_size, square_size)
    objpoints = []
    imgpoints = []
    image_size = None
    accepted_files = []
    rejected_files = []

    print("--- Detecting chessboard corners ---")
    print(f"Found {len(images)} candidate images")
    print(f"Chessboard internal corners: {chessboard_size}")
    print(f"Square size: {square_size} mm\n")

    for fname in images:
        img = cv2.imread(fname)
        if img is None:
            rejected_files.append(fname)
            print(f"Rejected unreadable image: {fname}")
            continue

        gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
        image_size = gray.shape[::-1]

        found, corners = find_corners(gray, chessboard_size, criteria)

        if found:
            objpoints.append(objp.copy())
            imgpoints.append(corners)
            accepted_files.append(fname)
            print(f"Accepted: {fname}")

            if show_corners:
                preview = img.copy()
                cv2.drawChessboardCorners(preview, chessboard_size, corners, found)
                cv2.imshow("Accepted calibration frame", preview)
                key = cv2.waitKey(preview_delay_ms)
                if key == 27:  # ESC
                    show_corners = False
                    cv2.destroyAllWindows()
        else:
            rejected_files.append(fname)
            print(f"Rejected: {fname}")

    cv2.destroyAllWindows()

    accepted = len(accepted_files)
    rejected = len(rejected_files)

    print("\n--- Detection Summary ---")
    print(f"Accepted: {accepted}")
    print(f"Rejected: {rejected}")

    if accepted < min_accepted_images:
        raise RuntimeError(
            f"Too few valid calibration images: {accepted}. "
            f"Try to get at least {min_accepted_images}-15 good detections."
        )

    rms_error, camera_matrix, dist_coeffs, rvecs, tvecs = cv2.calibrateCamera(
        objpoints,
        imgpoints,
        image_size,
        None,
        None,
    )

    mean_error = compute_mean_reprojection_error(
        objpoints,
        imgpoints,
        rvecs,
        tvecs,
        camera_matrix,
        dist_coeffs,
    )

    results = {
        "camera_matrix": camera_matrix,
        "dist_coeffs": dist_coeffs,
        "rms_error": rms_error,
        "mean_error": mean_error,
        "chessboard_size": np.array(chessboard_size),
        "square_size": square_size,
        "accepted_count": accepted,
        "rejected_count": rejected,
        "image_size": np.array(image_size),
    }

    return results


def save_calibration(results, output_file):
    """Save calibration results as a NumPy .npz file."""
    np.savez(output_file, **results)

    print("\n--- Calibration Results ---")
    print("RMS reprojection error from calibrateCamera():", results["rms_error"])
    print("Mean reprojection error:", results["mean_error"])
    print("\nCamera matrix:\n", results["camera_matrix"])
    print("\nDistortion coefficients:\n", results["dist_coeffs"].ravel())
    print(f"\nSaved calibration to: {output_file}")


def main():
    if EXTRACT_FRAMES:
        extract_candidate_frames(
            video_path=VIDEO_PATH,
            output_dir=OUTPUT_DIR,
            sample_every=SAMPLE_EVERY,
            clear_old_frames=CLEAR_OLD_FRAMES,
        )

    results = calibrate_from_images(
        image_folder=OUTPUT_DIR,
        image_extension=IMAGE_EXTENSION,
        chessboard_size=CHESSBOARD_SIZE,
        square_size=SQUARE_SIZE,
        min_accepted_images=MIN_ACCEPTED_IMAGES,
        show_corners=SHOW_CORNERS,
        preview_delay_ms=PREVIEW_DELAY_MS,
    )

    save_calibration(results, OUTPUT_CALIBRATION_FILE)


if __name__ == "__main__":
    main()
